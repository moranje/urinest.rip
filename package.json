{
  "name": "urinest-rip",
  "type": "module",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "check": "vue-tsc --noEmit",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "lint": "oxlint src/ --deny-warnings",
    "lint:eslint": "eslint src/",
    "lint:all": "oxlint src/ --deny-warnings && eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "oxlint --deny-warnings",
      "eslint"
    ],
    "*.{ts,vue,json,css}": "oxfmt --check"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "decision-engine-core": "file:decision-engine-core-1.0.0.tgz",
    "marked": "^17.0.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "6.0.2",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "7.2.4",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  }
}
